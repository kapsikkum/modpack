			y: 0.0d
		}
		{
			dependencies: ["F010"]
			description: [
				"Zombies are relentless \u2014 they call for reinforcements when hit and break down doors at night."
				""
				"Husks in desert biomes inflict Hunger on hit. Drowned in water can throw Tridents. Keep your hunger bar full."
				""
				"Smite enchantments on Simply Swords weapons deal bonus damage to all undead \u2014 craft a Longsword for extended reach."
			]
			id: "F011"
			rewards: [{
