			y: -2.0d
		}
		{
			dependencies: ["2F2E3D4C5B6A78A2"]
			description: [
				"With multiple named Waystones in your network, fast travel becomes trivial."
				""
				"§eTip§r: Name your Waystones clearly — base, mine, farm, nether portal — for a clean network."
				""
				"You can also carry a §ePocket Warpstone§r to teleport to any Waystone without needing to stand on one."
			]
			id: "2F2E3D4C5B6A78A3"
