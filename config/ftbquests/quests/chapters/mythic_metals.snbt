			}]
			title: "Orichalcum"
			subtitle: "The haste-granting armor"
			x: -2.0d
			y: -6.0d
		}
		{
			dependencies: ["9D06"]
			description: [
				"§bAdamantite§r is the hardest overworld metal in §bMythic Metals§r, found at Y=-60 to Y=-80 in the deepest layers of the world."
				""
				"Mine it with a diamond or better pickaxe. Smelt in a blast furnace. The §6Adamantite Sword§r is one of the strongest melee weapons in the pack, outdamaging Netherite significantly."
				""
				"Adamantite armor provides maximum physical protection. It is the strongest overworld tier before entering the Nether or End for Hallowed and Celestium."
				""
				"An §6Adamantite Anvil§r is also available \u2014 it functions as a regular anvil but doesn\u2019t lose durability per use."
			]
			icon: "mythicmetals:adamantite_ingot"
			id: "9D07"
			tasks: [{
				id: "9E07"
				item: "mythicmetals:adamantite_ingot"
				type: "item"
			}]
			title: "Adamantite"
			subtitle: "The hardest of overworld metals"
			rewards: [{
				id: "9F07"
				item: "mythicmetals:adamantite_ingot"
				count: 4
				type: "item"
			}]
			x: -2.0d
