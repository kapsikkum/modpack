	quests: [
		{
			description: [
				"§bEnd Remastered§r overhauls the End Portal. Instead of 12 identical Eyes of Ender, the portal now requires §c16 unique eyes§r \u2014 each tied to a different challenge across the world."
				""
				"No two eyes come from the same place. You'll need to face the Wither, storm Ocean Monuments, explore Ancient Cities, trade with Piglins, and more."
				""
				"Each quest below rewards one eye when you complete its challenge. Together, they map out your entire progression from Nether entry to End gateway."
				""
				"§7The portal won't open by chance. You'll have to earn it."
			]
			icon: "minecraft:end_portal_frame"
			id: "EA000002"
			optional: true
			size: 1.5d
			subtitle: "Click to learn more"
			tasks: [{
				id: "EA000003"
				title: "End Remastered \u2014 Sixteen Eyes, One Portal"
				type: "checkmark"
			}]
			title: "§6\u25C6 Gateway to the End"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["EA000002"]
			description: [
				"§7§oIt was lost by a demon in the battle between the Aether and the Nether.§r"
				""
				"The Nether Eye was carried by a demon slain long ago, its power scattered through the burning fortresses."
				""
				"Slay §cBlazes§r deep in Nether Fortresses. Collect their powder as proof you've stood in the fire."
			]
			icon: "endrem:nether_eye"
			id: "EA000011"
			rewards: [{
