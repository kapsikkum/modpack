		{
			dependencies: ["9A00"]
			description: [
				"§bHerbology§r is the discipline of growing and harvesting magical plants for use as ingredients across all other Witchcraft disciplines."
				""
				"The §bEnchanted: Witchcraft§r mod adds new trees, flowers, and herbs that spawn in the world and can be cultivated in your own witch\u2019s garden."
				""
				"Many potions, rituals, and poppets require specific herbs. Setting up a dedicated garden near your base ensures a reliable ingredient supply."
				""
				"The §6Witch\u2019s Oven§r is used to dry and process herbs for use in more advanced recipes."
			]
			icon: "enchanted:witch_oven"
			id: "9A04"
			tasks: [{
				id: "9B04"
				item: "enchanted:witch_oven"
				type: "item"
			}]
			title: "The Witch\u2019s Garden"
			subtitle: "Grow your own ingredients"
			rewards: [{
				id: "9C04"
				item: "enchanted:belladonna_seeds"
				count: 16
				type: "item"
			}]
			x: -2.0d
			y: -2.0d
