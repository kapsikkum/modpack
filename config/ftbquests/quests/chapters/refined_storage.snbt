	quests: [
		{
			dependencies: []
			description: [
				"§bRefined Storage§r is a digital item storage and automation mod built around §6ME Networks§r — interconnected machines that pool all your items into searchable virtual drives."
				""
				"Unlike §bApplied Energistics 2§r, Refined Storage uses straightforward crafting rather than inscribers, making it simpler to get started while remaining highly powerful."
				""
				"§7First material:§r §eSilicon§r — smelt any Sand in a furnace with Coal or Charcoal as fuel. One sand produces one Silicon."
				""
				"You'll need Silicon for every processor, so make at least 16 before you start."
			]
			icon: "refinedstorage:silicon"
			id: "D010"
			rewards: [
				{
					count: 8
					id: "D210"
					item: "minecraft:quartz"
					type: "item"
				}
			]
			tasks: [
				{
					count: 8L
					id: "D110"
					item: "refinedstorage:silicon"
					type: "item"
				}
			]
			title: "§6Sand and Coal, Refined"
			subtitle: "Smelt Sand with Coal to create Silicon — the foundation of all RS processors."
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["D010"]
			description: [
				"§eQuartz Enriched Iron§r is the second core Refined Storage ingredient alongside Silicon. You'll use it in every RS component."
				""
				"§7Recipe:§r Surround an Iron Ingot with 4 Nether Quartz in a + shape in the crafting grid."
				""
				"Build a generous supply early — Machine Casings alone consume 8 Quartz Enriched Iron each, and you'll need several."
			]
			icon: "refinedstorage:quartz_enriched_iron"
